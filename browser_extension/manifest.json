{
  "manifest_version": 3,
  "name": "Counter-Strikle 助手",
  "version": "2.1.0",
  "description": "在对战房间页面实时计算最优猜测建议，右上角浮层显示",
  "permissions": [],
  "host_permissions": [
    "https://blast.tv/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://blast.tv/counter-strikle/multiplayer/*"],
      "js": ["ws_hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://blast.tv/counter-strikle/multiplayer/*"],
      "js": ["analyzer.js", "content_script.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["players_data.json", "panel.css"],
      "matches": ["https://blast.tv/*"]
    }
  ]
}
